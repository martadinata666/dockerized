FROM 192.168.0.2:5050/dedyms/php-fpm:7.4 AS cache
ARG TOKEN
ARG RELEASE
WORKDIR /var/www/html/
ENV COMPOSER_MEMORY_LIMIT=3G
USER root
RUN apt update && \
    apt install -y --no-install-recommends git ca-certificates curl
# ./composer config -a github-oauth.github.com $TOKEN && \
#RUN wget https://github.com/martadinata666/heimdall-update/releases/download/$RELEASE/release.zip && \
#composer config -a github-oauth.github.com $TOKEN && \     
USER $CONTAINERUSER
RUN git clone --depth=1 -b ${RELEASE} https://github.com/linuxserver/Heimdall.git /var/www/html && \
    rm -rf ./.git && \
    curl -L https://getcomposer.org/download/latest-2.x/composer.phar -o ./composer.phar && \
    mv ./composer.phar ./composer && \
    chmod +x ./composer && \
    rm -rf vendor/ && \
    ./composer update && \     
    ./composer install --prefer-dist --no-dev --no-interaction && \     
    ./composer clear-cache && \
    rm -rf ./composer && \
    ls -al /var/www/html && \
    rm -rf public/storage && \
    php artisan db:seed && \
    php artisan storage:link


FROM 192.168.0.2:5050/dedyms/nginx:mainline-fpm
ARG RELEASE
ENV HEIMDALL_RELEASE=$RELEASE
COPY --from=cache --chown=$CONTAINERUSER:$CONTAINERUSER /var/www/html /var/www/html
RUN ls -al /var/www/html
COPY default.conf /etc/nginx/conf.d/default.conf
USER $CONTAINERUSER
WORKDIR /var/www/html
VOLUME ["/var/www/html/storage", "/var/www/html/database"]
